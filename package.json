{
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "vite": "^8.0.2"
  },
  "type": "module",
  "scripts": {
    "test": "NODE_OPTIONS='--experimental-transform-types --disable-warning=ExperimentalWarning' node --test test.ts 'src/**/*.test.ts'",
    "build": "esbuild --format=esm --bundle --outfile=index.js --platform=neutral src/index.ts",
    "enc": "./scripts/build-enc.ts > enc.json",
    "prepublishOnly": "node --run build"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./index.js"
    }
  },
  "name": "ok-emoji",
  "version": "4.1.4",
  "author": "Sam Thorogood <sam.thorogood@gmail.com>",
  "license": "Apache-2.0"
}
